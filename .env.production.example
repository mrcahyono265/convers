# Database
DATABASE_URL="postgresql://postgres:YOUR_STRONG_PASSWORD@your-db-host:5432/english_companion"

# JWT Secret (generate with: openssl rand -hex 32, then copy the output here)
JWT_SECRET="your-jwt-secret-here-must-be-at-least-32-chars"

# NVIDIA NIM API
NVIDIA_API_KEY="nvapi-your-key-here"
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"

# CORS origin (your production domain - no wildcard in production)
CORS_ORIGIN="https://your-domain.com"
