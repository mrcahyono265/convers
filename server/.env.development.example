# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/english_companion"

# JWT Secret (development only - generate a new one for production)
JWT_SECRET="dev-secret-do-not-use-in-production-1234567890abcdef"

# NVIDIA NIM API
NVIDIA_API_KEY="nvapi-your-key-here"
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"

# Server
PORT=3000
NODE_ENV=development

# CORS origin (Vite dev server + Bun dev server)
CORS_ORIGIN="http://localhost:5173"
